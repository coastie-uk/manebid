# Public hostname used by Caddy. Use localhost for local testing, or a DNS name
# pointing at this host for automatic public HTTPS.
MANEBID_SITE_ADDRESS=localhost

# Host ports. Public certificate issuance requires the standard 80/443 values.
MANEBID_HTTP_PORT=80
MANEBID_HTTPS_PORT=443

# Container timezone used by SQLite's localtime timestamps.
TZ=Europe/London

# These paths are resolved relative to deploy/docker/.
MANEBID_CONFIG_SOURCE=./backend-config.json
MANEBID_SECRET_FILE=./manebid.env

# Optional local image tag used by Compose.
MANEBID_IMAGE_TAG=local
